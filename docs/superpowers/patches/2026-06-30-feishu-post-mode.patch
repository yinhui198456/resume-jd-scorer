Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 .../unit/bridge-feishu-streaming.test.ts      | 277 ++++++++++++++++++
 1 file changed, 277 insertions(+)
 create mode 100644 src/__tests__/unit/bridge-feishu-streaming.test.ts

diff --git a/src/__tests__/unit/bridge-feishu-streaming.test.ts b/src/__tests__/unit/bridge-feishu-streaming.test.ts
new file mode 100644
index 0000000..6d2e4d2
--- /dev/null
+++ b/src/__tests__/unit/bridge-feishu-streaming.test.ts
@@ -0,0 +1,277 @@
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+import { FeishuAdapter } from '../../lib/bridge/adapters/feishu-adapter';
+import { initBridgeContext } from '../../lib/bridge/context';
+import type { BridgeStore } from '../../lib/bridge/host';
+
+function setupContext(settings: Record<string, string | null>) {
+  initBridgeContext({
+    store: {
+      getSetting: (key: string) => settings[key] ?? null,
+      setSetting: () => {},
+      getChannelOffset: () => '0',
+      setChannelOffset: () => {},
+      insertAuditLog: () => {},
+      listPendingPermissionLinksByChat: () => [],
+    } as unknown as BridgeStore,
+    llm: {} as any,
+    permissions: {} as any,
+    lifecycle: {},
+  });
+}
+
+describe('FeishuAdapter streaming cards', () => {
+  it('uses the SDK CardKit v1 lifecycle for create, stream, and finalize', async () => {
+    setupContext({});
+    const calls: Array<{ method: string; payload: any }> = [];
+    const client = {
+      cardkit: {
+        v1: {
+          card: {
+            create: async (payload: any) => {
+              calls.push({ method: 'card.create', payload });
+              return { code: 0, data: { card_id: 'card-1' } };
+            },
+            settings: async (payload: any) => {
+              calls.push({ method: 'card.settings', payload });
+              return { code: 0, data: {} };
+            },
+            update: async (payload: any) => {
+              calls.push({ method: 'card.update', payload });
+              return { code: 0, data: {} };
+            },
+          },
+          cardElement: {
+            content: async (payload: any) => {
+              calls.push({ method: 'cardElement.content', payload });
+              return { code: 0, data: {} };
+            },
+          },
+        },
+      },
+      im: {
+        message: {
+          reply: async (payload: any) => {
+            calls.push({ method: 'message.reply', payload });
+            return { code: 0, data: { message_id: 'message-1' } };
+          },
+        },
+      },
+    };
+
+    const adapter = new FeishuAdapter() as any;
+    adapter.restClient = client;
+
+    const created = await adapter._doCreateStreamingCard('chat-1', 'incoming-1');
+    assert.equal(created, true);
+    assert.equal(calls[0].method, 'card.create');
+    assert.equal(calls[1].method, 'message.reply');
+
+    adapter.updateCardContent('chat-1', 'partial response');
+    await new Promise((resolve) => setImmediate(resolve));
+
+    const streamCall = calls.find((call) => call.method === 'cardElement.content');
+    assert.ok(streamCall);
+    assert.deepEqual(streamCall.payload.path, {
+      card_id: 'card-1',
+      element_id: 'streaming_content',
+    });
+    assert.equal(streamCall.payload.data.content.includes('partial response'), true);
+
+    const finalized = await adapter.onStreamEnd('chat-1', 'completed', 'final response');
+    assert.equal(finalized, true);
+
+    const settingsCall = calls.find((call) => call.method === 'card.settings');
+    assert.ok(settingsCall);
+    assert.deepEqual(JSON.parse(settingsCall.payload.data.settings), {
+      streaming_mode: false,
+    });
+
+    const updateCall = calls.find((call) => call.method === 'card.update');
+    assert.ok(updateCall);
+    assert.equal(updateCall.payload.data.card.type, 'card_json');
+    assert.equal(updateCall.payload.data.card.data.includes('final response'), true);
+  });
+
+  it('sends copyable text when bridge_feishu_message_style is text', async () => {
+    setupContext({ bridge_feishu_message_style: 'text' });
+    const calls: Array<{ method: string; payload: any }> = [];
+    const client = {
+      im: {
+        message: {
+          create: async (payload: any) => {
+            calls.push({ method: 'message.create', payload });
+            return { code: 0, data: { message_id: 'message-text' } };
+          },
+        },
+      },
+    };
+
+    const adapter = new FeishuAdapter() as any;
+    adapter.restClient = client;
+
+    const result = await adapter.send({
+      address: { channelType: 'feishu', chatId: 'chat-1', userId: 'user-1' },
+      text: '每日 AI 资讯\\n━━━━━━━━━━━━━━━━\\n01｜测试',
+      parseMode: 'Markdown',
+    });
+
+    assert.equal(result.ok, true);
+    assert.equal(calls[0].payload.data.msg_type, 'text');
+    assert.deepEqual(JSON.parse(calls[0].payload.data.content), {
+      text: '每日 AI 资讯\\n━━━━━━━━━━━━━━━━\\n01｜测试',
+    });
+  });
+
+  it('sends post message when bridge_feishu_message_style is post', async () => {
+    setupContext({ bridge_feishu_message_style: 'post' });
+    const calls: Array<{ method: string; payload: any }> = [];
+    const client = {
+      im: {
+        message: {
+          create: async (payload: any) => {
+            calls.push({ method: 'message.create', payload });
+            return { code: 0, data: { message_id: 'message-post' } };
+          },
+        },
+      },
+    };
+
+    const adapter = new FeishuAdapter() as any;
+    adapter.restClient = client;
+
+    const result = await adapter.send({
+      address: { channelType: 'feishu', chatId: 'chat-1', userId: 'user-1' },
+      text: '**加粗标题**\n\n- 列表项 A\n- 列表项 B',
+      parseMode: 'Markdown',
+    });
+
+    assert.equal(result.ok, true);
+    assert.equal(calls[0].payload.data.msg_type, 'post');
+    const postContent = JSON.parse(calls[0].payload.data.content);
+    assert.equal(postContent.zh_cn.content[0][0].tag, 'md');
+    assert.equal(postContent.zh_cn.content[0][0].text.includes('加粗标题'), true);
+  });
+
+  it('does not create streaming cards when bridge_feishu_message_style is text', async () => {
+    setupContext({ bridge_feishu_message_style: 'text' });
+    const calls: Array<{ method: string; payload: any }> = [];
+    const client = {
+      cardkit: {
+        v1: {
+          card: {
+            create: async (payload: any) => {
+              calls.push({ method: 'card.create', payload });
+              return { code: 0, data: { card_id: 'card-1' } };
+            },
+          },
+          cardElement: {
+            content: async (payload: any) => {
+              calls.push({ method: 'cardElement.content', payload });
+              return { code: 0, data: {} };
+            },
+          },
+        },
+      },
+      im: {
+        messageReaction: {
+          create: async (payload: any) => {
+            calls.push({ method: 'messageReaction.create', payload });
+            return { code: 0, data: { reaction_id: 'reaction-1' } };
+          },
+        },
+      },
+    };
+
+    const adapter = new FeishuAdapter() as any;
+    adapter.restClient = client;
+    adapter.lastIncomingMessageId.set('chat-1', 'incoming-1');
+
+    adapter.onMessageStart('chat-1');
+    adapter.onStreamText('chat-1', 'partial response');
+    adapter.onToolEvent('chat-1', [{ id: 'tool-1', name: 'tool', status: 'running' }]);
+    const finalized = await adapter.onStreamEnd('chat-1', 'completed', 'final response');
+    await new Promise((resolve) => setImmediate(resolve));
+
+    assert.equal(finalized, false);
+    assert.equal(calls.some((call) => call.method === 'card.create'), false);
+    assert.equal(calls.some((call) => call.method === 'cardElement.content'), false);
+  });
+
+  it('does not create streaming cards when bridge_feishu_message_style is post', async () => {
+    setupContext({ bridge_feishu_message_style: 'post' });
+    const calls: Array<{ method: string; payload: any }> = [];
+    const client = {
+      cardkit: {
+        v1: {
+          card: {
+            create: async (payload: any) => {
+              calls.push({ method: 'card.create', payload });
+              return { code: 0, data: { card_id: 'card-1' } };
+            },
+          },
+          cardElement: {
+            content: async (payload: any) => {
+              calls.push({ method: 'cardElement.content', payload });
+              return { code: 0, data: {} };
+            },
+          },
+        },
+      },
+      im: {
+        messageReaction: {
+          create: async (payload: any) => {
+            calls.push({ method: 'messageReaction.create', payload });
+            return { code: 0, data: { reaction_id: 'reaction-1' } };
+          },
+        },
+      },
+    };
+
+    const adapter = new FeishuAdapter() as any;
+    adapter.restClient = client;
+    adapter.lastIncomingMessageId.set('chat-1', 'incoming-1');
+
+    adapter.onMessageStart('chat-1');
+    adapter.onStreamText('chat-1', 'partial response');
+    adapter.onToolEvent('chat-1', [{ id: 'tool-1', name: 'tool', status: 'running' }]);
+    const finalized = await adapter.onStreamEnd('chat-1', 'completed', 'final response');
+    await new Promise((resolve) => setImmediate(resolve));
+
+    assert.equal(finalized, false);
+    assert.equal(calls.some((call) => call.method === 'card.create'), false);
+    assert.equal(calls.some((call) => call.method === 'cardElement.content'), false);
+  });
+
+  it('keeps permission prompts interactive when bridge_feishu_message_style is text', async () => {
+    setupContext({ bridge_feishu_message_style: 'text' });
+    const calls: Array<{ method: string; payload: any }> = [];
+    const client = {
+      im: {
+        message: {
+          create: async (payload: any) => {
+            calls.push({ method: 'message.create', payload });
+            return { code: 0, data: { message_id: 'message-card' } };
+          },
+        },
+      },
+    };
+
+    const adapter = new FeishuAdapter() as any;
+    adapter.restClient = client;
+
+    const result = await adapter.send({
+      address: { channelType: 'feishu', chatId: 'chat-1', userId: 'user-1' },
+      text: '<b>Permission Required</b>',
+      parseMode: 'HTML',
+      inlineButtons: [[
+        { text: 'Allow once', callbackData: 'perm:allow:permission-1' },
+        { text: 'Deny', callbackData: 'perm:deny:permission-1' },
+      ]],
+    });
+
+    assert.equal(result.ok, true);
+    assert.equal(calls[0].payload.data.msg_type, 'interactive');
+    assert.equal(calls[0].payload.data.content.includes('permission-1'), true);
+  });
+});
