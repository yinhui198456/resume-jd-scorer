From 9963ef7e2194b8469c3131255a915158dba5c8eb Mon Sep 17 00:00:00 2001
From: root <root@localhost.localdomain>
Date: Tue, 30 Jun 2026 20:29:45 +0800
Subject: [PATCH 2/3] fix(feishu): skip streaming cards in post mode

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 src/lib/bridge/adapters/feishu-adapter.ts | 10 ++++++----
 1 file changed, 6 insertions(+), 4 deletions(-)

diff --git a/src/lib/bridge/adapters/feishu-adapter.ts b/src/lib/bridge/adapters/feishu-adapter.ts
index d777289..1aeca7b 100644
--- a/src/lib/bridge/adapters/feishu-adapter.ts
+++ b/src/lib/bridge/adapters/feishu-adapter.ts
@@ -9,6 +9,8 @@
  * - Code blocks / tables → interactive card (schema 2.0 markdown)
  * - Other text → post (msg_type: 'post') with md tag
  * - Permission prompts → interactive card with action buttons
+ * - Config `CTI_FEISHU_MESSAGE_STYLE=post` forces all normal replies to post
+ *   and disables streaming cards for mobile copyability.
  *
  * card.action.trigger events are handled via EventDispatcher (Openclaw pattern):
  * button clicks are converted to synthetic text messages and routed through
@@ -267,7 +269,7 @@ export class FeishuAdapter extends BaseChannelAdapter {
     const messageId = this.lastIncomingMessageId.get(chatId);
 
     // Create streaming card (fire-and-forget — fallback to traditional if fails)
-    if (messageId && !this.prefersTextMessages()) {
+    if (messageId && !this.prefersTextMessages() && !this.prefersPostMessages()) {
       this.createStreamingCard(chatId, messageId).catch(() => {});
     }
 
@@ -610,7 +612,7 @@ export class FeishuAdapter extends BaseChannelAdapter {
    * Creates streaming card on first call, then updates content.
    */
   onStreamText(chatId: string, fullText: string): void {
-    if (this.prefersTextMessages()) return;
+    if (this.prefersTextMessages() || this.prefersPostMessages()) return;
 
     if (!this.activeCards.has(chatId)) {
       // Card should have been created by onMessageStart, but create lazily if not
@@ -624,13 +626,13 @@ export class FeishuAdapter extends BaseChannelAdapter {
   }
 
   onToolEvent(chatId: string, tools: ToolCallInfo[]): void {
-    if (this.prefersTextMessages()) return;
+    if (this.prefersTextMessages() || this.prefersPostMessages()) return;
 
     this.updateToolProgress(chatId, tools);
   }
 
   async onStreamEnd(chatId: string, status: 'completed' | 'interrupted' | 'error', responseText: string): Promise<boolean> {
-    if (this.prefersTextMessages()) return false;
+    if (this.prefersTextMessages() || this.prefersPostMessages()) return false;
 
     return this.finalizeCard(chatId, status, responseText);
   }
