+  /**
+   * Send text as a copyable Feishu text message.
+   * Used when mobile copyability is more important than rich rendering.
+   */
+  private async sendAsText(chatId: string, text: string): Promise<SendResult> {
+    try {
+      const res = await this.restClient!.im.message.create({
+        params: { receive_id_type: 'chat_id' },
+        data: {
+          receive_id: chatId,
+          msg_type: 'text',
+          content: JSON.stringify({ text }),
+        },
+      });
+      if (res?.data?.message_id) {
+        return { ok: true, messageId: res.data.message_id };
+      }
+      return { ok: false, error: res?.msg || 'Send failed' };
+    } catch (err) {
+      return { ok: false, error: err instanceof Error ? err.message : 'Send failed' };
+    }
+  }
+
+  private prefersPostMessages(): boolean {
+    return getBridgeContext().store.getSetting('bridge_feishu_message_style') === 'post';
+  }
+
+  private prefersTextMessages(): boolean {
+    return getBridgeContext().store.getSetting('bridge_feishu_message_style') === 'text';
+  }
+
   /**
    * Send text as an interactive card (schema 2.0 markdown).
    * Used for code blocks and tables — card renders them properly.
@@ -711,22 +764,7 @@ export class FeishuAdapter extends BaseChannelAdapter {
     }
 
